# ============================================
# Campus DID - Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!
# For deployment guide: see VERCEL_RENDER_DEPLOYMENT.md

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=3001
BACKEND_URL=http://localhost:3001

# ============================================
# Algorand Configuration
# ============================================
# Network: 'testnet' or 'mainnet'
ALGORAND_NETWORK=testnet

# Algorand Node (TestNet)
ALGORAND_ALGOD_SERVER=https://testnet-api.algonode.cloud
ALGORAND_ALGOD_PORT=443
ALGORAND_ALGOD_TOKEN=

# Algorand Indexer (TestNet)
ALGORAND_INDEXER_SERVER=https://testnet-idx.algonode.cloud
ALGORAND_INDEXER_PORT=443
ALGORAND_INDEXER_TOKEN=

# Smart Contract App ID (deployed on Algorand)
# Get this from deploying contracts/deploy.py
ALGORAND_APP_ID=756415000

# University/Issuer Account Mnemonic (25 words)
# Get test ALGO from: https://dispenser.testnet.aws.algodev.network/
UNIVERSITY_MNEMONIC=your twenty five word mnemonic phrase goes here and should be kept secret

# ============================================
# IPFS Configuration (Pinata)
# ============================================
# Sign up at: https://pinata.cloud
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_api_key_here
PINATA_GATEWAY=https://gateway.pinata.cloud

# ============================================
# Security (Production Only)
# ============================================
# JWT Secret (generate with: openssl rand -base64 64)
# JWT_SECRET=your-very-long-random-jwt-secret-string-here

# API Key for admin endpoints (optional)
# API_KEY=your-api-key-for-admin-access

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ============================================
# Rate Limiting (Production)
# ============================================
# Time window in milliseconds (default: 15 minutes)
# RATE_LIMIT_WINDOW_MS=900000

# Max requests per IP per window (default: 100)
# RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Logging
# ============================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# ============================================
# Database (Future Enhancement)
# ============================================
# For production, replace in-memory storage with database
# DATABASE_URL=postgresql://user:password@localhost:5432/campus_did
# REDIS_URL=redis://localhost:6379

# ============================================
# Monitoring (Optional)
# ============================================
# SENTRY_DSN=your-sentry-dsn-for-error-tracking
