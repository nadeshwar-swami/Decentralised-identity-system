# =============================================
# Campus DID - Frontend Environment Variables
# =============================================
# Copy this file to .env and fill in your values

# =============================================
# Backend API Configuration
# =============================================
# URL of the backend API server
VITE_BACKEND_URL=http://localhost:3001

# =============================================
# Algorand Network Configuration
# =============================================
# Algorand network: 'testnet' or 'mainnet'
VITE_ALGORAND_NETWORK=testnet

# Algorand Node URL (TestNet)
VITE_ALGOD_URL=https://testnet-api.algonode.cloud
VITE_ALGOD_PORT=443

# Algorand Indexer URL (TestNet)
VITE_INDEXER_URL=https://testnet-idx.algonode.cloud
VITE_INDEXER_PORT=443

# =============================================
# Smart Contract
# =============================================
# App ID of deployed smart contract on Algorand
# Get this from deploying contracts/deploy.py
VITE_APP_ID=756415000

# =============================================
# Production Configuration (Optional)
# =============================================
# For production deployment, update to your domain:
# VITE_BACKEND_URL=https://api.campus-did.com
# VITE_ALGORAND_NETWORK=mainnet
# VITE_ALGOD_URL=https://mainnet-api.algonode.cloud
# VITE_INDEXER_URL=https://mainnet-idx.algonode.cloud
# VITE_APP_ID=your_mainnet_app_id

# =============================================
# Feature Flags (Optional)
# =============================================
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_DEBUG=false
